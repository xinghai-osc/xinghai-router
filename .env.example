# docker compose reads these values from this file.
ENCRYPTION_KEY=replace-this-with-a-separate-random-secret-at-least-24-characters
# Keep this URL-safe because it is embedded in DATABASE_URL by Compose.
POSTGRES_PASSWORD=replace-with-a-strong-database-password
# Optional Redis for shared API-key rate limiting across instances.
# Compose sets REDIS_URL automatically; leave empty for single-process in-memory limiter.
# REDIS_URL=redis://127.0.0.1:6379/0
ROUTER_PORT=8080
WEB_PORT=3000
# Optional Geetest v4 CAPTCHA for login/register. Leave empty to disable.
GEETEST_CAPTCHA_ID=
GEETEST_CAPTCHA_KEY=
# Optional SMTP for registration email verification codes. Leave SMTP_HOST empty to disable.
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
# Optional bootstrap admin identity (created on first start when no admin exists).
# Password is randomly generated and printed once in the router logs.
# BOOTSTRAP_ADMIN_EMAIL=admin@localhost
# BOOTSTRAP_ADMIN_NAME=Administrator
