# Required secrets — compose fails fast if unset. Never commit a real .env.
ENCRYPTION_KEY=replace-with-a-unique-random-secret-at-least-24-chars
# Keep URL-safe (no @ : / ? #) because it is embedded in DATABASE_URL.
POSTGRES_PASSWORD=replace-with-a-strong-database-password
REDIS_PASSWORD=replace-with-a-strong-redis-password

# Optional overrides (compose sets REDIS_URL with REDIS_PASSWORD by default).
# REDIS_URL=redis://:password@redis:6379/0
# POSTGRES_DATA_PATH=/mnt/data/AI-Router/postgres
# REDIS_DATA_PATH=/mnt/data/AI-Router/redis

ROUTER_PORT=8080
WEB_PORT=3000

# Optional Geetest v4 CAPTCHA for login/register. Leave empty to disable.
GEETEST_CAPTCHA_ID=
GEETEST_CAPTCHA_KEY=

# Optional SMTP for registration email verification codes. Leave SMTP_HOST empty to disable.
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# Optional bootstrap admin identity (created on first start when no admin exists).
# Password is randomly generated and printed once in the router logs.
# BOOTSTRAP_ADMIN_EMAIL=admin@localhost
# BOOTSTRAP_ADMIN_NAME=Administrator
