# docker compose reads these values from this file.
ENCRYPTION_KEY=replace-this-with-a-separate-random-secret-at-least-24-characters
# Keep this URL-safe because it is embedded in DATABASE_URL by Compose.
POSTGRES_PASSWORD=replace-with-a-strong-database-password
ROUTER_PORT=8080
WEB_PORT=3000
# Optional Geetest v4 CAPTCHA for login/register. Leave empty to disable.
GEETEST_CAPTCHA_ID=
GEETEST_CAPTCHA_KEY=
# Optional SMTP for registration email verification codes. Leave SMTP_HOST empty to disable.
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# Comma-separated proxy IPs/CIDRs allowed to set X-Forwarded-For / X-Real-IP for client IP
# (rate limits, audit logs). Empty = never trust proxy headers (use RemoteAddr only).
# Keywords: loopback, private. Example behind compose/Caddy on the host network:
# TRUSTED_PROXIES=loopback,private
# TRUSTED_PROXIES=
